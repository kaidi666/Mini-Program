/* 主题变量 - 浅色模式（默认） */
page {
  --bg-color: #F5F5F5;
  --card-bg: #FFFFFF;
  --text-color: #333333;
  --text-secondary: #999999;
  --border-color: #E5E5E5;
  --primary-color: #3498DB;
  --priority-high: #E74C3C;
  --priority-medium: #F39C12;
  --priority-low: #27AE60;
  background-color: #F5F5F5;
  color: #333333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  min-height: 100vh;
}

/* 深色模式 - 通过容器class切换 */
.dark-mode {
  --bg-color: #1A1A1A;
  --card-bg: #2D2D2D;
  --text-color: #FFFFFF;
  --text-secondary: #AAAAAA;
  --border-color: #404040;
}

.dark-mode .card {
  background-color: #2D2D2D;
}

.dark-mode .section-title {
  color: #AAAAAA;
}

.dark-mode .setting-label {
  color: #FFFFFF;
}

.dark-mode .setting-desc {
  color: #AAAAAA;
}

.dark-mode .setting-value {
  color: #AAAAAA;
}

.dark-mode .history-week {
  color: #FFFFFF;
}

.dark-mode .week-number {
  color: #FFFFFF;
}

.dark-mode .priority-title {
  color: #FFFFFF;
}

.dark-mode .empty-text {
  color: #FFFFFF;
}

.dark-mode .task-title {
  color: #FFFFFF;
}

.dark-mode .modal-title {
  color: #FFFFFF;
}

.dark-mode .form-label {
  color: #AAAAAA;
}

.dark-mode .form-input {
  background-color: #1A1A1A;
  color: #FFFFFF;
}

.dark-mode .form-picker {
  background-color: #1A1A1A;
  color: #FFFFFF;
}

.dark-mode .priority-option {
  background-color: #1A1A1A;
}

.dark-mode .btn-cancel {
  color: #AAAAAA;
}

.dark-mode .btn-confirm {
  color: #3498DB;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

/* 按钮样式 */
.btn-primary {
  background-color: var(--primary-color);
  color: #FFFFFF;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

/* 优先级标签 */
.priority-high {
  color: var(--priority-high);
}

.priority-medium {
  color: var(--priority-medium);
}

.priority-low {
  color: var(--priority-low);
}
