<view class="dish-item {{showActions ? 'show-actions' : ''}}" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">
  <view class="dish-header">
    <view class="dish-name">{{dish.name}}</view>
    <view class="dish-actions">
      <view class="action-btn edit-btn" catchtap="onEditTap">
        <text>编辑</text>
      </view>
      <view class="action-btn delete-btn" catchtap="onDeleteTap">
        <text>删除</text>
      </view>
    </view>
  </view>
  <view class="dish-tags" wx:if="{{dish.tags && dish.tags.length > 0}}">
    <view class="dish-tag" wx:for="{{dish.tags}}" wx:key="index">
      <text>{{item}}</text>
    </view>
  </view>
  <view class="dish-info">
    <view class="dish-ingredients" wx:if="{{dish.ingredients}}">
      <text class="info-label">食材：</text>
      <text class="info-value">{{dish.ingredients}}</text>
    </view>
    <view class="dish-remark" wx:if="{{dish.remark}}">
      <text class="info-label">备注：</text>
      <text class="info-value">{{dish.remark}}</text>
    </view>
  </view>
</view>
