.dish-item {
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  background-color: var(--card-bg);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.dish-item:active {
  transform: scale(0.98);
}

.dish-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-color);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-actions {
  display: flex;
  gap: 16rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.dish-item.show-actions .dish-actions {
  opacity: 1;
}

.action-btn {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.edit-btn {
  background-color: var(--primary-color);
  color: #FFFFFF;
}

.delete-btn {
  background-color: var(--priority-high);
  color: #FFFFFF;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.dish-tag {
  padding: 6rpx 16rpx;
  background-color: var(--primary-color);
  color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.dish-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dish-ingredients,
.dish-remark {
  display: flex;
  font-size: 26rpx;
  line-height: 1.5;
}

.info-label {
  color: var(--text-secondary);
  flex-shrink: 0;
}

.info-value {
  color: var(--text-color);
  flex: 1;
  word-break: break-all;
}

