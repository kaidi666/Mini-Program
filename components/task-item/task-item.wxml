<view class="task-item {{completed ? 'completed' : ''}}" bindtap="onTap">
  <view class="task-checkbox" catchtap="onCheckTap">
    <view class="checkbox {{completed ? 'checked' : ''}} priority-{{priority}}">
      <text wx:if="{{completed}}" class="check-icon">✓</text>
    </view>
  </view>
  <view class="task-content">
    <view class="task-title">{{title}}</view>
    <view class="task-meta">
      <text class="task-date" wx:if="{{dueDate}}">📅 {{dueDate}}</text>
    </view>
  </view>
  <view class="task-actions">
    <view class="action-btn edit-btn" catchtap="onEditTap">
      <text>编辑</text>
    </view>
    <view class="action-btn delete-btn" catchtap="onDeleteTap">
      <text>删除</text>
    </view>
  </view>
</view>
