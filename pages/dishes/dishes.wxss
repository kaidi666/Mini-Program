.container {
  padding: 20rpx;
  padding-bottom: 180rpx;
  min-height: 100vh;
}

/* 筛选区 */
.filter-section {
  background-color: var(--card-bg);
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}

.filter-scroll {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-btn {
  padding: 12rpx 24rpx;
  background-color: var(--bg-color);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.2s ease;
}

.filter-btn.active {
  background-color: var(--primary-color);
  color: #FFFFFF;
}

.filter-btn:active {
  opacity: 0.8;
}

/* 菜品列表 */
.dish-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-color);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  bottom: 180rpx;
  background-color: var(--primary-color);
  color: #FFFFFF;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(52, 152, 219, 0.4);
}

.add-btn:active {
  opacity: 0.8;
  transform: translateX(-50%) scale(0.98);
}

/* 深色模式 */
.dark-mode .filter-btn {
  background-color: #1A1A1A;
}

.dark-mode .empty-text {
  color: #FFFFFF;
}
