.container {
  padding: 20rpx;
  min-height: 100vh;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 16rpx 0;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.setting-content {
  flex: 1;
}

.setting-label {
  font-size: 30rpx;
  color: var(--text-color);
  display: block;
  margin-bottom: 4rpx;
}

.setting-label.danger {
  color: var(--priority-high);
}

.setting-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.setting-value {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.setting-arrow {
  font-size: 36rpx;
  color: var(--text-secondary);
  margin-left: 16rpx;
}
