/* weekly-plan/pages/meal-config/meal-config.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.container.dark-mode {
  background: #1A1A1A;
}

.meal-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.dark-mode .meal-list {
  background: #2A2A2A;
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.dark-mode .meal-item {
  border-bottom-color: #3A3A3A;
}

.meal-item:last-child {
  border-bottom: none;
}

.meal-checkbox {
  margin-right: 20rpx;
}

.checkbox {
  font-size: 40rpx;
  color: #ccc;
}

.checkbox.checked {
  color: #3498DB;
}

.meal-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.dark-mode .meal-name {
  color: #fff;
}

.meal-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 28rpx;
  color: #3498DB;
  padding: 8rpx 16rpx;
}

.add-section {
  display: flex;
  gap: 16rpx;
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
}

.dark-mode .add-section {
  background: #2A2A2A;
}

.add-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.dark-mode .add-input {
  border-color: #444;
  color: #fff;
}

.add-btn {
  padding: 0 32rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #3498DB;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}
