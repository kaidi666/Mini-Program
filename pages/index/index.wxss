.container {
  padding: 20rpx;
  padding-bottom: 180rpx;
  min-height: 100vh;
}

/* 周信息头部 */
.week-header {
  text-align: center;
  padding: 32rpx;
}

.week-title {
  margin-bottom: 8rpx;
}

.week-number {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-color);
}

.week-date {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}

/* 进度条 */
.progress-section {
  margin-top: 24rpx;
}

.progress-label {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.progress-percent {
  color: var(--primary-color);
  font-weight: bold;
}

.progress-bar {
  height: 16rpx;
  background-color: var(--border-color);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: var(--primary-color);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
}

/* 优先级分组 */
.priority-section {
  margin-bottom: 24rpx;
}

.priority-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.priority-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.priority-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-color);
}

.priority-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-color);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  bottom: 180rpx;
  background-color: var(--primary-color);
  color: #FFFFFF;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(52, 152, 219, 0.4);
}

.add-btn:active {
  opacity: 0.8;
  transform: translateX(-50%) scale(0.98);
}
